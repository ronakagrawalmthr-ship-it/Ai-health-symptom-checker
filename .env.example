# AI Health Symptom Checker - Environment Variables Template
# Copy this file to .env and fill in your values

# OpenAI API Key (OPTIONAL - get from https://platform.openai.com/api-keys)
# If not provided, the app will use the built-in symptom database (50+ conditions)
# No API key needed - works automatically for all customers!
OPENAI_API_KEY=

# Google Maps API Key (OPTIONAL - get from https://console.cloud.google.com/)
# Required for Find Doctors map feature
# If not provided, the app will show mock doctor data for demonstration
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Flask Configuration (optional)
FLASK_DEBUG=False
PORT=5000
